//Summarize Js Basics Results
function summarizeJsBasicsResults(results) {
  let summary = {
    total: results.length,
    passed: 0,
    failed: 0,
    skipped: 0
  };

  for (let result of results) {
    let value = result.toLowerCase();

    if (value.includes("pass")) {
      summary.passed++;
    }

    if (value.includes("fail")) {
      summary.failed++;
    }

    if (value.includes("skip")) {
      summary.skipped++;
    }
  }

  return summary;
}
